<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_File_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_File_1" isExecutable="false">
    <bpmn:startEvent id="StartEvent_File_1" name="收到文档">
      <bpmn:outgoing>Flow_File_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_File_1" name="解析图表">
      <bpmn:incoming>Flow_File_1</bpmn:incoming>
      <bpmn:outgoing>Flow_File_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_File_1" name="输出预览">
      <bpmn:incoming>Flow_File_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_File_1" sourceRef="StartEvent_File_1" targetRef="Task_File_1" />
    <bpmn:sequenceFlow id="Flow_File_2" sourceRef="Task_File_1" targetRef="EndEvent_File_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_File_1">
    <bpmndi:BPMNPlane id="BPMNPlane_File_1" bpmnElement="Process_File_1">
      <bpmndi:BPMNShape id="StartEvent_File_1_di" bpmnElement="StartEvent_File_1">
        <dc:Bounds x="120" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_File_1_di" bpmnElement="Task_File_1">
        <dc:Bounds x="220" y="58" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_File_1_di" bpmnElement="EndEvent_File_1">
        <dc:Bounds x="420" y="80" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_File_1_di" bpmnElement="Flow_File_1">
        <di:waypoint x="156" y="98" />
        <di:waypoint x="220" y="98" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_File_2_di" bpmnElement="Flow_File_2">
        <di:waypoint x="340" y="98" />
        <di:waypoint x="420" y="98" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
