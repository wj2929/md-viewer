<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_Parallel_Review_File" targetNamespace="http://md-viewer.local/parallel-review-file">
  <bpmn:process id="Process_Parallel_Review_File" isExecutable="false">
    <bpmn:startEvent id="Start_PRF" name="提交方案"><bpmn:outgoing>PRF_1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="Task_PRF_Normalize" name="规范化文档"><bpmn:incoming>PRF_1</bpmn:incoming><bpmn:outgoing>PRF_2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_PRF_Split" name="并行评审"><bpmn:incoming>PRF_2</bpmn:incoming><bpmn:outgoing>PRF_3</bpmn:outgoing><bpmn:outgoing>PRF_4</bpmn:outgoing><bpmn:outgoing>PRF_5</bpmn:outgoing></bpmn:parallelGateway>
    <bpmn:userTask id="Task_PRF_Arch" name="架构评审"><bpmn:incoming>PRF_3</bpmn:incoming><bpmn:outgoing>PRF_6</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Task_PRF_UX" name="交互评审"><bpmn:incoming>PRF_4</bpmn:incoming><bpmn:outgoing>PRF_7</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Task_PRF_Test" name="自动化检查"><bpmn:incoming>PRF_5</bpmn:incoming><bpmn:outgoing>PRF_8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_PRF_Join" name="汇总意见"><bpmn:incoming>PRF_6</bpmn:incoming><bpmn:incoming>PRF_7</bpmn:incoming><bpmn:incoming>PRF_8</bpmn:incoming><bpmn:outgoing>PRF_9</bpmn:outgoing></bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="Gateway_PRF_Result" name="通过?"><bpmn:incoming>PRF_9</bpmn:incoming><bpmn:outgoing>PRF_10</bpmn:outgoing><bpmn:outgoing>PRF_11</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_PRF_Revise" name="人工修订"><bpmn:incoming>PRF_11</bpmn:incoming><bpmn:outgoing>PRF_12</bpmn:outgoing></bpmn:manualTask>
    <bpmn:endEvent id="End_PRF_Pass" name="进入实施"><bpmn:incoming>PRF_10</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="End_PRF_Back" name="退回补充"><bpmn:incoming>PRF_12</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="PRF_1" sourceRef="Start_PRF" targetRef="Task_PRF_Normalize" />
    <bpmn:sequenceFlow id="PRF_2" sourceRef="Task_PRF_Normalize" targetRef="Gateway_PRF_Split" />
    <bpmn:sequenceFlow id="PRF_3" sourceRef="Gateway_PRF_Split" targetRef="Task_PRF_Arch" />
    <bpmn:sequenceFlow id="PRF_4" sourceRef="Gateway_PRF_Split" targetRef="Task_PRF_UX" />
    <bpmn:sequenceFlow id="PRF_5" sourceRef="Gateway_PRF_Split" targetRef="Task_PRF_Test" />
    <bpmn:sequenceFlow id="PRF_6" sourceRef="Task_PRF_Arch" targetRef="Gateway_PRF_Join" />
    <bpmn:sequenceFlow id="PRF_7" sourceRef="Task_PRF_UX" targetRef="Gateway_PRF_Join" />
    <bpmn:sequenceFlow id="PRF_8" sourceRef="Task_PRF_Test" targetRef="Gateway_PRF_Join" />
    <bpmn:sequenceFlow id="PRF_9" sourceRef="Gateway_PRF_Join" targetRef="Gateway_PRF_Result" />
    <bpmn:sequenceFlow id="PRF_10" name="是" sourceRef="Gateway_PRF_Result" targetRef="End_PRF_Pass" />
    <bpmn:sequenceFlow id="PRF_11" name="否" sourceRef="Gateway_PRF_Result" targetRef="Task_PRF_Revise" />
    <bpmn:sequenceFlow id="PRF_12" sourceRef="Task_PRF_Revise" targetRef="End_PRF_Back" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="D_Parallel_Review_File">
    <bpmndi:BPMNPlane id="P_Parallel_Review_File" bpmnElement="Process_Parallel_Review_File">
      <bpmndi:BPMNShape id="Start_PRF_di" bpmnElement="Start_PRF"><dc:Bounds x="40" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PRF_Normalize_di" bpmnElement="Task_PRF_Normalize"><dc:Bounds x="120" y="138" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PRF_Split_di" bpmnElement="Gateway_PRF_Split"><dc:Bounds x="300" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PRF_Arch_di" bpmnElement="Task_PRF_Arch"><dc:Bounds x="430" y="50" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PRF_UX_di" bpmnElement="Task_PRF_UX"><dc:Bounds x="430" y="145" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PRF_Test_di" bpmnElement="Task_PRF_Test"><dc:Bounds x="430" y="240" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PRF_Join_di" bpmnElement="Gateway_PRF_Join"><dc:Bounds x="630" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PRF_Result_di" bpmnElement="Gateway_PRF_Result"><dc:Bounds x="760" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PRF_Revise_di" bpmnElement="Task_PRF_Revise"><dc:Bounds x="900" y="240" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_PRF_Pass_di" bpmnElement="End_PRF_Pass"><dc:Bounds x="930" y="85" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_PRF_Back_di" bpmnElement="End_PRF_Back"><dc:Bounds x="1080" y="257" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="PRF_1_di" bpmnElement="PRF_1"><di:waypoint x="76" y="178" /><di:waypoint x="120" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_2_di" bpmnElement="PRF_2"><di:waypoint x="240" y="178" /><di:waypoint x="300" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_3_di" bpmnElement="PRF_3"><di:waypoint x="325" y="153" /><di:waypoint x="430" y="85" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_4_di" bpmnElement="PRF_4"><di:waypoint x="350" y="178" /><di:waypoint x="430" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_5_di" bpmnElement="PRF_5"><di:waypoint x="325" y="203" /><di:waypoint x="430" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_6_di" bpmnElement="PRF_6"><di:waypoint x="550" y="85" /><di:waypoint x="655" y="153" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_7_di" bpmnElement="PRF_7"><di:waypoint x="550" y="180" /><di:waypoint x="630" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_8_di" bpmnElement="PRF_8"><di:waypoint x="550" y="275" /><di:waypoint x="655" y="203" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_9_di" bpmnElement="PRF_9"><di:waypoint x="680" y="178" /><di:waypoint x="760" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_10_di" bpmnElement="PRF_10"><di:waypoint x="785" y="153" /><di:waypoint x="930" y="103" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_11_di" bpmnElement="PRF_11"><di:waypoint x="785" y="203" /><di:waypoint x="900" y="275" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="PRF_12_di" bpmnElement="PRF_12"><di:waypoint x="1020" y="275" /><di:waypoint x="1080" y="275" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
