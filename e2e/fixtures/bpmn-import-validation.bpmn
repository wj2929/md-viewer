<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Defs_Import_Validation_File" targetNamespace="http://md-viewer.local/import-validation-file">
  <bpmn:process id="Process_Import_Validation_File" isExecutable="false">
    <bpmn:startEvent id="Start_IVF" name="选择文件"><bpmn:outgoing>IVF_1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="Task_IVF_Read" name="读取 Markdown"><bpmn:incoming>IVF_1</bpmn:incoming><bpmn:outgoing>IVF_2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:businessRuleTask id="Task_IVF_Path" name="路径白名单"><bpmn:incoming>IVF_2</bpmn:incoming><bpmn:outgoing>IVF_3</bpmn:outgoing></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_IVF_Path" name="路径有效?"><bpmn:incoming>IVF_3</bpmn:incoming><bpmn:outgoing>IVF_4</bpmn:outgoing><bpmn:outgoing>IVF_5</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:scriptTask id="Task_IVF_Parse" name="解析图表块"><bpmn:incoming>IVF_4</bpmn:incoming><bpmn:outgoing>IVF_6</bpmn:outgoing></bpmn:scriptTask>
    <bpmn:parallelGateway id="Gateway_IVF_Split" name="分类校验"><bpmn:incoming>IVF_6</bpmn:incoming><bpmn:outgoing>IVF_7</bpmn:outgoing><bpmn:outgoing>IVF_8</bpmn:outgoing><bpmn:outgoing>IVF_9</bpmn:outgoing></bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_IVF_Local" name="本地渲染器"><bpmn:incoming>IVF_7</bpmn:incoming><bpmn:outgoing>IVF_10</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Task_IVF_Remote" name="外部引用"><bpmn:incoming>IVF_8</bpmn:incoming><bpmn:outgoing>IVF_11</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="Task_IVF_Manual" name="人工确认"><bpmn:incoming>IVF_9</bpmn:incoming><bpmn:outgoing>IVF_12</bpmn:outgoing></bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_IVF_Join" name="合并结果"><bpmn:incoming>IVF_10</bpmn:incoming><bpmn:incoming>IVF_11</bpmn:incoming><bpmn:incoming>IVF_12</bpmn:incoming><bpmn:outgoing>IVF_13</bpmn:outgoing></bpmn:parallelGateway>
    <bpmn:exclusiveGateway id="Gateway_IVF_Result" name="可预览?"><bpmn:incoming>IVF_13</bpmn:incoming><bpmn:outgoing>IVF_14</bpmn:outgoing><bpmn:outgoing>IVF_15</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_IVF_Render" name="打开预览"><bpmn:incoming>IVF_14</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="End_IVF_Error" name="显示错误"><bpmn:incoming>IVF_5</bpmn:incoming><bpmn:incoming>IVF_15</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="IVF_1" sourceRef="Start_IVF" targetRef="Task_IVF_Read" />
    <bpmn:sequenceFlow id="IVF_2" sourceRef="Task_IVF_Read" targetRef="Task_IVF_Path" />
    <bpmn:sequenceFlow id="IVF_3" sourceRef="Task_IVF_Path" targetRef="Gateway_IVF_Path" />
    <bpmn:sequenceFlow id="IVF_4" name="是" sourceRef="Gateway_IVF_Path" targetRef="Task_IVF_Parse" />
    <bpmn:sequenceFlow id="IVF_5" name="否" sourceRef="Gateway_IVF_Path" targetRef="End_IVF_Error" />
    <bpmn:sequenceFlow id="IVF_6" sourceRef="Task_IVF_Parse" targetRef="Gateway_IVF_Split" />
    <bpmn:sequenceFlow id="IVF_7" sourceRef="Gateway_IVF_Split" targetRef="Task_IVF_Local" />
    <bpmn:sequenceFlow id="IVF_8" sourceRef="Gateway_IVF_Split" targetRef="Task_IVF_Remote" />
    <bpmn:sequenceFlow id="IVF_9" sourceRef="Gateway_IVF_Split" targetRef="Task_IVF_Manual" />
    <bpmn:sequenceFlow id="IVF_10" sourceRef="Task_IVF_Local" targetRef="Gateway_IVF_Join" />
    <bpmn:sequenceFlow id="IVF_11" sourceRef="Task_IVF_Remote" targetRef="Gateway_IVF_Join" />
    <bpmn:sequenceFlow id="IVF_12" sourceRef="Task_IVF_Manual" targetRef="Gateway_IVF_Join" />
    <bpmn:sequenceFlow id="IVF_13" sourceRef="Gateway_IVF_Join" targetRef="Gateway_IVF_Result" />
    <bpmn:sequenceFlow id="IVF_14" name="是" sourceRef="Gateway_IVF_Result" targetRef="End_IVF_Render" />
    <bpmn:sequenceFlow id="IVF_15" name="否" sourceRef="Gateway_IVF_Result" targetRef="End_IVF_Error" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="D_Import_Validation_File">
    <bpmndi:BPMNPlane id="P_Import_Validation_File" bpmnElement="Process_Import_Validation_File">
      <bpmndi:BPMNShape id="Start_IVF_di" bpmnElement="Start_IVF"><dc:Bounds x="40" y="170" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IVF_Read_di" bpmnElement="Task_IVF_Read"><dc:Bounds x="120" y="148" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IVF_Path_di" bpmnElement="Task_IVF_Path"><dc:Bounds x="280" y="148" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IVF_Path_di" bpmnElement="Gateway_IVF_Path"><dc:Bounds x="450" y="163" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IVF_Parse_di" bpmnElement="Task_IVF_Parse"><dc:Bounds x="570" y="148" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IVF_Split_di" bpmnElement="Gateway_IVF_Split"><dc:Bounds x="740" y="163" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IVF_Local_di" bpmnElement="Task_IVF_Local"><dc:Bounds x="870" y="60" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IVF_Remote_di" bpmnElement="Task_IVF_Remote"><dc:Bounds x="870" y="155" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_IVF_Manual_di" bpmnElement="Task_IVF_Manual"><dc:Bounds x="870" y="250" width="120" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IVF_Join_di" bpmnElement="Gateway_IVF_Join"><dc:Bounds x="1070" y="163" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IVF_Result_di" bpmnElement="Gateway_IVF_Result"><dc:Bounds x="1200" y="163" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_IVF_Render_di" bpmnElement="End_IVF_Render"><dc:Bounds x="1350" y="110" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_IVF_Error_di" bpmnElement="End_IVF_Error"><dc:Bounds x="1350" y="245" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="IVF_1_di" bpmnElement="IVF_1"><di:waypoint x="76" y="188" /><di:waypoint x="120" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_2_di" bpmnElement="IVF_2"><di:waypoint x="240" y="188" /><di:waypoint x="280" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_3_di" bpmnElement="IVF_3"><di:waypoint x="400" y="188" /><di:waypoint x="450" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_4_di" bpmnElement="IVF_4"><di:waypoint x="500" y="188" /><di:waypoint x="570" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_5_di" bpmnElement="IVF_5"><di:waypoint x="475" y="213" /><di:waypoint x="475" y="263" /><di:waypoint x="1350" y="263" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_6_di" bpmnElement="IVF_6"><di:waypoint x="690" y="188" /><di:waypoint x="740" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_7_di" bpmnElement="IVF_7"><di:waypoint x="765" y="163" /><di:waypoint x="870" y="95" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_8_di" bpmnElement="IVF_8"><di:waypoint x="790" y="188" /><di:waypoint x="870" y="190" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_9_di" bpmnElement="IVF_9"><di:waypoint x="765" y="213" /><di:waypoint x="870" y="285" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_10_di" bpmnElement="IVF_10"><di:waypoint x="990" y="95" /><di:waypoint x="1095" y="163" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_11_di" bpmnElement="IVF_11"><di:waypoint x="990" y="190" /><di:waypoint x="1070" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_12_di" bpmnElement="IVF_12"><di:waypoint x="990" y="285" /><di:waypoint x="1095" y="213" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_13_di" bpmnElement="IVF_13"><di:waypoint x="1120" y="188" /><di:waypoint x="1200" y="188" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_14_di" bpmnElement="IVF_14"><di:waypoint x="1225" y="163" /><di:waypoint x="1350" y="128" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="IVF_15_di" bpmnElement="IVF_15"><di:waypoint x="1225" y="213" /><di:waypoint x="1350" y="263" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
